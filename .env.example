# ======================== 环境变量配置示例 ========================
# 复制此文件为 .env 并填写实际值：
#   copy .env.example .env  (Windows)
#   cp .env.example .env    (Linux/Mac)
#
# ⚠️ 绝对不要将 .env 文件提交到 Git！

# ======================== 数据库配置 ========================
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_PORT=5432
DB_NAME=

# ======================== 剪映配置 ========================
JIANYING_DRAFT_PATH=
JIANYING_EXE_PATH=

# ======================== BGM 配置 ========================
BGM_DIR=
BGM_VOLUME=0.02

# ======================== 目录配置 ========================
MATERIAL_BASE_DIR=coze_workflow_works
VIDEO_EXPORT_DIR=exported_videos

# ======================== 处理配置 ========================
MAX_PROCESS_COUNT=12
